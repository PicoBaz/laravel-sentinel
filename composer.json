{
    "name": "picobaz/laravel-sentinel",
    "description": "Advanced monitoring and alerting system for Laravel applications with real-time notifications",
    "keywords": [
        "laravel",
        "monitoring",
        "performance",
        "alerting",
        "sentinel",
        "logging",
        "security",
        "ai",
        "machine-learning",
        "predictions",
        "cost-optimization",
        "infrastructure",
        "finops",
        "observability",
        "apm"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "PicoBaz",
            "email": "picobaz3@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PicoBaz\\Sentinel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PicoBaz\\Sentinel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PicoBaz\\Sentinel\\Providers\\SentinelServiceProvider"
            ],
            "aliases": {
                "Sentinel": "PicoBaz\\Sentinel\\Facades\\Sentinel"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "meta-box/composer-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
